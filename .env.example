# Copy file ini menjadi .env dan isi nilainya

# Database (Railway akan otomatis set ini)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Redis (Railway akan otomatis set ini jika tambah Redis service)
REDIS_URL=redis://localhost:6379/0

# JWT - WAJIB diganti dengan string random yang panjang
JWT_SECRET_KEY=ganti-dengan-random-string-panjang-minimal-32-karakter
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# TikTok Shop API
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=

# WhatsApp Meta Cloud API
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=

# OpenAI (opsional, untuk NLP)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS - isi dengan URL frontend Vercel setelah deploy
ALLOWED_ORIGINS=https://your-app.vercel.app
