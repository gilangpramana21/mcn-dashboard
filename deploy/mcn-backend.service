[Unit]
Description=MCN Backend (FastAPI)
After=network.target postgresql.service

[Service]
User=ubuntu
WorkingDirectory=/var/www/mcn-dashboard
Environment="PATH=/var/www/mcn-dashboard/venv/bin"
EnvironmentFile=/var/www/mcn-dashboard/.env
ExecStart=/var/www/mcn-dashboard/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
